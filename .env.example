SECRET_KEY=replace-this-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=.vercel.app,your-domain.com
CSRF_TRUSTED_ORIGINS=https://*.vercel.app,https://your-domain.com

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_SECONDS=20

# Use hosted PostgreSQL for Vercel, such as Neon from the Vercel Marketplace.
# Leave empty only for local SQLite development.
DATABASE_URL=
